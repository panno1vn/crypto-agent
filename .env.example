# ==========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==========================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=crypto_agent
DATABASE_URL=postgresql+asyncpg://admin:your_secure_password@localhost:5432/crypto_agent

# ==========================================
# DATA PIPELINE (Telegram + Binance)
# ==========================================
# Lấy từ https://my.telegram.org
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Binance Testnet API Keys
BINANCE_API_KEY=your_binance_testnet_key
BINANCE_SECRET=your_binance_testnet_secret

# ==========================================
# AI / LLM CONFIGURATION
# ==========================================
# Dùng cho Docker gọi ngược ra WSL2
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ==========================================
# RAG PIPELINE (ChromaDB)
# ==========================================
CHROMA_HOST=localhost
CHROMA_PORT=8000